# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:2b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_KEEP_ALIVE=600
OLLAMA_NUM_PARALLEL=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_NUM_CTX_MAX=4096
OLLAMA_NUM_THREADS=0

# Benchmark
HECVAT_PATH=./samples/sample_hecvat_template.xlsx
HECVAT_PROFILE=./config/hecvat_profile.yaml
PROMPT_PATH=./config/prompts/gap_analysis.txt
KB_DIR=./knowledge_base
CHROMA_DIR=./chroma
RETRIEVAL_K=4
BENCHMARK_ITEMS=20           # how many HECVAT items to run per benchmark session
BENCHMARK_RESULTS_PATH=docs/benchmark_results.md

# Models — suggestions only, NOT a hard limit. Any Ollama model name works.
# Add gemma3:4b, phi4-mini:3.8b, llama3.2:3b, mistral, gemma2:9b, qwen2.5:7b, etc.
MODEL_SHORTLIST=gemma3:2b,phi4-mini:3.8b,gemma3:4b,llama3.2:3b,mistral,gemma2:9b,qwen2.5:7b

# Logging
LOG_LEVEL=INFO
